# Database (Get from neon.tech)
DATABASE_URL=postgresql://user:password@host/database

# Redis (Get from upstash.com)
REDIS_URL=redis://default:password@host:port

# GitHub OAuth (Get from github.com/settings/developers)
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID_HERE
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET_HERE

# JWT Secret (Generate random 32+ characters)
JWT_SECRET=your_random_secret_min_32_characters_long_here

# Encryption Key (Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=YOUR_64_CHAR_HEX_KEY_HERE

# Server Configuration
PORT=3000
CORS_ORIGIN=*
NODE_ENV=development

# Instructions:
# 1. Copy this file to .env
# 2. Replace all YOUR_*_HERE values with actual values
# 3. Never commit .env file to git

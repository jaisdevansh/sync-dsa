{
  "manifest_version": 3,
  "name": "DSA Auto Sync",
  "version": "1.0.0",
  "description": "Automatically sync your DSA solutions to GitHub",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://www.geeksforgeeks.org/*",
    "https://www.codingninjas.com/*",
    "https://www.naukri.com/code360/*",
    "http://localhost:3000/*",
    "https://sync-dsa-2ha0.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://practice.geeksforgeeks.org/problems/*",
        "https://www.geeksforgeeks.org/problems/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.codingninjas.com/studio/problems/*",
        "https://www.codingninjas.com/codestudio/problems/*",
        "https://www.naukri.com/code360/problems/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://sync-dsa-2ha0.onrender.com/*",
        "http://localhost:3000/*"
      ],
      "js": ["auth-content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
